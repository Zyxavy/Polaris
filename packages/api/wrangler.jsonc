{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "paragon-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-07",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true,
    "logs": { "head_sampling_rate": 1 },
    "traces": { "enabled": true, "head_sampling_rate": 0.01 }
  },

  "triggers": {
    "crons": ["0 15 * * *"]
  },

  "queues": {
    "producers": [
      {
        "binding": "JOURNAL_RETRY_QUEUE",
        "queue": "paragon-journal-retry"
      }
    ]
  },

  "vars": {
    "MONGODB_URI": "mongodb://localhost:27017/paragon"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "paragon-db-dev",
      "database_id": "bd7d9f42-2c4a-442c-9fd0-a53ded81cc6c"
    }
  ],

  "r2_buckets": [
    {
      "bucket_name": "paragon-attachments",
      "binding": "ATTACHMENTS"
    }
  ],

  "env": {
    "production": {
      "queues": {
        "producers": [
          { "binding": "JOURNAL_RETRY_QUEUE", "queue": "paragon-journal-retry" }
        ]
      },
      "r2_buckets": [
        { "bucket_name": "paragon-attachments", "binding": "ATTACHMENTS" }
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "paragon-db",
          "database_id": "6072aa3b-6fad-48a4-b2d6-72eaaaef6a3e"
        }
      ]
    }
  }
}