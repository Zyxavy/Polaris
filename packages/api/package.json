{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler d1 migrations apply DB && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test:integration": "vitest",
    "test:unit": "vitest run",
    "test:int": "vitest run",
    "dev:e2e": "wrangler d1 migrations apply DB --local && wrangler dev --port 8787",
    "build": "wrangler types --env-interface CloudflareBindings",
    "lint": "eslint src/"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "hono": "^4.12.27",
    "mongodb": "^7.5.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@types/node": "^26.1.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.4.0"
  }
}